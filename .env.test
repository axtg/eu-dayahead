# Test Environment Configuration
NODE_ENV=test
PORT=3001

# API Keys
# ENTSOE_API_KEY is intentionally not pinned here so local runs pick up the real key from .env
# (via tests/setup.js fallback) while CI runs without it (and exercises the Stekker fallback path).
LOGTAIL_TOKEN=
LOGTAIL_ENDPOINT=

# Cache Configuration (shorter for tests)
CACHE_TIMEOUT_MS=1000

# Rate Limiting (per-IP, requests/sec; very permissive for tests)
RATE_LIMIT_RPS=10000

# CORS Configuration
CORS_ORIGIN=*

# Logging (reduced for tests)
LOG_LEVEL=error