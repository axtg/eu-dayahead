# Server Configuration
PORT=3000
NODE_ENV=development

# API Keys
STEKKER_API_KEY=your-stekker-api-key-here
ENTSOE_API_KEY=your-entsoe-api-key-here
LOGTAIL_TOKEN=your-logtail-token-here
LOGTAIL_ENDPOINT=your-logtail-http-endpoint-here

# Cache: upstream raw prices are cached per country, keyed by today's local
# date. Entries auto-refresh after the daily ENTSOE publish boundary
# (~14:30 CET) and roll over at country-local midnight, so we make at most
# ~2 upstream calls per country per day. No knob.

# Rate Limiting
# Max requests per IP per second for /api endpoints
RATE_LIMIT_RPS=10

# CORS Configuration
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info

# Optional: Custom API Base URL for documentation
API_BASE_URL=http://localhost:3000
